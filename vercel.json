{
  "version": 2,
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/(image|whatever)/(.*)/(.*)",
      "dest": "/api/assets.php?type=$1&parent=$2&file=$3"
    },
    {
      "src": "/(css|js|image|favicon.ico)/(.*)",
      "dest": "/api/assets.php?type=$1&file=$2"
    },
    { "src": "/galeria",  "dest": "/api/galeria.php" },
    { "src": "/(.*)",  "dest": "/api/index.php" }
  ]
}
